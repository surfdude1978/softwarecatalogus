# =============================================================================
# Softwarecatalogus — Productie omgevingsvariabelen
# Kopieer naar .env.production en vul ALLE waarden in
# NOOIT dit bestand committen met echte waarden!
# =============================================================================

# --- Database (PostgreSQL) ---
POSTGRES_DB=softwarecatalogus
POSTGRES_USER=swc
POSTGRES_PASSWORD=VERANDER_DIT_STERK_WACHTWOORD
DATABASE_URL=postgresql://swc:VERANDER_DIT_STERK_WACHTWOORD@db:5432/softwarecatalogus

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Meilisearch ---
MEILISEARCH_URL=http://meilisearch:7700
MEILISEARCH_API_KEY=VERANDER_DIT_STERKE_API_SLEUTEL_MIN_16_TEKENS

# --- Django ---
DJANGO_SETTINGS_MODULE=config.settings.production
# Genereer met: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=GENEREER_MET_PYTHON_SECRETS_TOKEN_URLSAFE_50
DEBUG=False
# Vul in: je domeinnaam of het server-IP
ALLOWED_HOSTS=204.168.145.63,jouwdomein.nl,www.jouwdomein.nl
CSRF_TRUSTED_ORIGINS=https://jouwdomein.nl,https://www.jouwdomein.nl

# --- Email (gebruik een echte SMTP-provider in productie) ---
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=SENDGRID_OF_ANDERE_SMTP_SLEUTEL
DEFAULT_FROM_EMAIL=no-reply@jouwdomein.nl

# --- Storage ---
MEDIA_ROOT=/app/media

# --- Domein (voor SSL en Nginx) ---
DOMAIN_NAME=jouwdomein.nl

# --- Matomo ---
MATOMO_URL=https://matomo.jouwdomein.nl
MATOMO_SITE_ID=1

# --- TenderNed ---
TENDERNED_DEMO_MODE=False
TENDERNED_API_URL=https://www.tenderned.nl/papi/tenderned-rs-tns/v2/publicaties
TENDERNED_TIMEOUT=60

# --- AI-assistent (optioneel) ---
# Sleutel aanvragen: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# --- Frontend (Next.js) ---
# Gebruik je domeinnaam of het server-IP met https://
NEXT_PUBLIC_API_URL=https://jouwdomein.nl
NEXT_PUBLIC_MATOMO_URL=https://matomo.jouwdomein.nl
NEXT_PUBLIC_MATOMO_SITE_ID=1
