# =============================================================================
# Softwarecatalogus — Omgevingsvariabelen
# Kopieer dit bestand naar .env en pas de waarden aan
# =============================================================================

# --- Database (PostgreSQL) ---
POSTGRES_DB=softwarecatalogus
POSTGRES_USER=swc
POSTGRES_PASSWORD=swc
DATABASE_URL=postgresql://swc:swc@db:5432/softwarecatalogus

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Meilisearch ---
MEILISEARCH_URL=http://meilisearch:7700
MEILISEARCH_API_KEY=masterkey_dev_only

# --- Django ---
DJANGO_SETTINGS_MODULE=config.settings.development
SECRET_KEY=django-insecure-change-this-in-production-abc123
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# --- Email (DKIM/DMARC vereist in productie) ---
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=no-reply@softwarecatalogus.nl
EMAIL_HOST_PASSWORD=

# --- Storage ---
MEDIA_ROOT=/app/media

# --- Matomo ---
MATOMO_URL=https://matomo.softwarecatalogus.nl
MATOMO_SITE_ID=1

# --- TenderNed Open Data integratie ---
# Demo-modus (True): gebruik voorbeelddata — geschikt voor ontwikkeling en testen.
# Productie-modus (False): verbinding met echte TenderNed papi REST API (geen sleutel vereist).
TENDERNED_DEMO_MODE=True
TENDERNED_API_URL=https://www.tenderned.nl/papi/tenderned-rs-tns/v2/publicaties
TENDERNED_TIMEOUT=30
# Productie-instellingen: TENDERNED_DEMO_MODE=False, TENDERNED_TIMEOUT=60

# --- Frontend (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_MATOMO_URL=
NEXT_PUBLIC_MATOMO_SITE_ID=
